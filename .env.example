# Copy to .env and fill in values
DATABASE_URL=postgresql+asyncpg://telemetry:secret@localhost:5432/telemetry
DATABASE_REPLICA_URL=postgresql+asyncpg://telemetry:secret@localhost:5432/telemetry
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development
DEBUG=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60
CACHE_TTL_FLEET_SUMMARY=60
CACHE_TTL_HOURLY_STATS=300
CACHE_TTL_LATEST_EVENT=10
CACHE_TTL_LOW_BATTERY=30
